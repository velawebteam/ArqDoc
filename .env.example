# AI API Keys
# Gemini API Key (Default) - Often pre-configured
GEMINI_API_KEY=

# OpenRouter API Key (Mandatory fallback if Gemini 403 fails)
# Get your key at https://openrouter.ai/
# In AI Studio: go to Settings > Secrets and add 'OPENROUTER_API_KEY'
OPENROUTER_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
